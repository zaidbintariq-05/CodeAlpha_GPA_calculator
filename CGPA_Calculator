#include<iostream>
using namespace std;
 int main
{
 int n;
cout << "Enter number of courses: ";
    cin >> n;

    string course[20];
    float grade[20];
    int credit[20];

    float totalGradePoints = 0;
    int totalCredits = 0;
    
    cout<<endl;
 for (int i = 0; i < n; i++) 
	{
        cout << "Course " << i + 1 << endl;

        cout << "Enter course name: ";
        cin >> course[i];

        cout << "Enter grade point: ";
        cin >> grade[i];

        cout << "Enter credit hours: ";
        cin >> credit[i];

        totalGradePoints += grade[i] * credit[i];
        totalCredits += credit[i];
    }
 float cgpa = totalGradePoints / totalCredits;
cout << "FINAL RESULT";

    for (int i = 0; i < n; i++) 
	{
        cout << course[i]<<" Grade: " << grade[i]<<" Credit Hours: " << credit[i]<< endl;
    }
    cout<<endl;
    cout << "Total Credits = " << totalCredits << endl;
    cout << "CGPA = " << cgpa << endl;

    return 0;
}
